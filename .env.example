# Sentry DSN. Пусто/не задано => Sentry не инициализируется (см. src/index.js).
# ВАЖНО: любая переменная с префиксом REACT_APP_ инлайнится в публичный клиентский
# бандл при сборке — никогда не помещайте сюда реальные секреты/приватные ключи.
REACT_APP_SENTRY_DSN=your_sentry_dsn_here

# API Endpoints
REACT_APP_API_URL=http://localhost:5000

# Other
REACT_APP_ENVIRONMENT=development
